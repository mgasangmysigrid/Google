# Auth.js v5. Login is email/password (single demo credential below); Google is
# used only for the separate "Connect Gmail" flow.
# Generate AUTH_SECRET with `openssl rand -base64 32`.
AUTH_SECRET=
AUTH_URL=https://app.mysigrid.com

# Single demo login (email/password). Used by the credentials provider in auth.ts.
DEMO_EMAIL=
DEMO_PASSWORD=

# Google OAuth for the "Connect Gmail" flow only (not login).
# AUTH_GOOGLE_ID / AUTH_GOOGLE_SECRET come from Google Cloud Console -> APIs &
# Services -> Credentials -> Web application. Enable the Gmail API on the project.
# Authorized redirect URI must be `{AUTH_URL}/api/communications/google/callback`.
# Requested scopes: gmail.readonly, gmail.send, gmail.modify.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Key used to encrypt Google OAuth tokens at rest (AES-256-GCM).
# Generate with `openssl rand -base64 32`. Rotating this invalidates stored
# tokens (users simply re-connect Google).
TOKEN_ENCRYPTION_KEY=

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Public base URL of this app (used for unsubscribe links in outbound emails).
NEXT_PUBLIC_BASE_URL=https://app.mysigrid.com